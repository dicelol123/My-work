# bot.py
import asyncio
from aiogram import Bot, Dispatcher, types
from aiogram.filters import Command

# Сюда нужно будет вставить токен от BotFather
API_TOKEN = 'ВАШ_ТОКЕН_ТУТ'

bot = Bot(token=API_TOKEN)
dp = Dispatcher()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(f"Привет, {message.from_user.full_name}! Я твой личный ассистент по рынку игроков.")

@dp.message(Command("help"))
async def cmd_help(message: types.Message):
    await message.answer("Я могу анализировать цены и давать советы по трейдингу.")

async def main():
    print("Бот запущен...")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
